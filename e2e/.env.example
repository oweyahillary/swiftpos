# ── SwiftPOS E2E config ───────────────────────────────────────────────
# Copy this file to `.env` (in the same e2e/ folder) and fill in values.
# `.env` is gitignored — never commit real credentials.

# Target under test. Leave as-is for local; set to your staging URL to test
# a deployed dashboard instead (the API it talks to must be reachable too).
PLAYWRIGHT_BASE_URL=http://localhost:5173

# ── Owner login (Supabase email + password) — fill this in ────────────
OWNER_EMAIL=
OWNER_PASSWORD=

# ── POS staff (email + PIN) ───────────────────────────────────────────
# You do NOT need to fill these by hand: run `npm run seed:users` and it
# creates the users and writes these values automatically.
MANAGER_EMAIL=
MANAGER_PIN=
SUPERVISOR_EMAIL=
SUPERVISOR_PIN=
CASHIER_EMAIL=
CASHIER_PIN=
WAITER_EMAIL=
WAITER_PIN=
