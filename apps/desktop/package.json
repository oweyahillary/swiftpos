{
  "name": "desktop",
  "version": "0.0.1",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"tsc -p tsconfig.main.json --watch\" \"vite\" \"wait-on http://localhost:5174 dist/main/index.js && electron .\"",
    "build": "tsc && vite build && electron-builder",
    "build:renderer": "vite build",
    "lint": "echo 'lint desktop'",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@swiftpos/db": "workspace:*",
    "@swiftpos/sync": "workspace:*",
    "@swiftpos/ui": "workspace:*",
    "better-sqlite3": "^11.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/react": "^18.3.22",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "electron": "35.7.5",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.swiftpos.desktop",
    "productName": "SwiftPOS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "resources/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    }
  }
}
