# Dashboard (Vite) environment — set these in Vercel → Project → Settings → Environment Variables.
# All VITE_* vars are baked into the build, so a change requires a redeploy.

# URL of the API server (the Render service). No trailing slash.
VITE_API_URL=https://swiftpos-server.onrender.com

# Supabase project (Project Settings → API)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional — only needed if product/image uploads are used (Cloudinary)
# VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
# VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset
